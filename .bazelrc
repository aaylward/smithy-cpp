# Platform-specific configs (build:linux / build:macos / build:windows) apply automatically.
common --enable_platform_specific_config

# C++20 everywhere (ADR-0003 baseline; see docs/PLAN.md §2).
build:linux --cxxopt=-std=c++20 --host_cxxopt=-std=c++20
build:macos --cxxopt=-std=c++20 --host_cxxopt=-std=c++20
build:windows --cxxopt=/std:c++20 --host_cxxopt=/std:c++20

test --test_output=errors

# AddressSanitizer: bazel test //... --config=asan
build:asan --strip=never
build:asan --copt=-fsanitize=address
build:asan --copt=-fno-omit-frame-pointer
build:asan --copt=-g
build:asan --linkopt=-fsanitize=address

# UndefinedBehaviorSanitizer: bazel test //... --config=ubsan
# Assumes clang (CC=clang CXX=clang++): Bazel links through the C driver, which
# omits the UBSan C++ runtime (vptr checks) unless asked for it explicitly.
build:ubsan --strip=never
build:ubsan --copt=-fsanitize=undefined
build:ubsan --copt=-fno-sanitize-recover=all
build:ubsan --copt=-g
build:ubsan --linkopt=-fsanitize=undefined
build:ubsan --linkopt=-fno-sanitize-recover=all
build:ubsan --linkopt=-fsanitize-link-c++-runtime

# CI settings.
build:ci --announce_rc --verbose_failures

# Personal overrides stay out of version control.
try-import %workspace%/.bazelrc.user

# The code generator is Java 17 (matching the Gradle toolchain); rules_java
# compiles and runs it on a hermetic remote JDK.
common --java_language_version=17
common --tool_java_language_version=17
common --java_runtime_version=remotejdk_17
common --tool_java_runtime_version=remotejdk_17
