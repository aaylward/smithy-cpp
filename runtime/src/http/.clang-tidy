# Scoped exclusion: boost::asio::thread_pool's destructor chain trips a
# clang-analyzer false positive (the analyzer models the execution_context
# base destructor before the derived body, then reports use-after-free on
# service_registry_ inside boost's own ipp). thread_pool.hpp is included
# only by beast_transport.cc, so the check stays enabled everywhere else —
# see the root .clang-tidy's convention note.
InheritParentConfig: true
Checks: "-clang-analyzer-cplusplus.NewDelete"
